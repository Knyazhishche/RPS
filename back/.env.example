NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

DATABASE_URL=postgresql://rps:rps@localhost:5432/rps
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=rps.events

JWT_SECRET=replace-me-with-long-random-secret
JWT_EXPIRES_SEC=604800

TELEGRAM_BOT_TOKEN=123456:telegram-bot-token
TELEGRAM_AUTH_MAX_AGE_SEC=86400

COMMIT_PHASE_SEC=30
REVEAL_PHASE_SEC=30
RAKE_BPS=200
WORKER_TICK_MS=5000
